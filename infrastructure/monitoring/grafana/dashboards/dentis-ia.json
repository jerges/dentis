{
  "title": "Dentis — Asistente IA",
  "uid": "dentis-ia",
  "tags": ["dentis", "ia"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "clinic_id",
        "label": "Clínica",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(dentis_ia_tokens_total, clinic_id)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Requests totales al asistente",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(dentis_ia_request_seconds_count{application=\"dentis\", clinic_id=~\"$clinic_id\"})",
        "legendFormat": "requests"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Latencia P95 (s)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, sum(rate(dentis_ia_request_seconds_bucket{application=\"dentis\", clinic_id=~\"$clinic_id\"}[5m])) by (le))",
        "legendFormat": "p95"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Tokens totales",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(dentis_ia_tokens_total{application=\"dentis\", clinic_id=~\"$clinic_id\"})",
        "legendFormat": "tokens"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Coste acumulado (USD)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum(dentis_ia_cost_usd_total{application=\"dentis\", clinic_id=~\"$clinic_id\"})",
        "legendFormat": "cost"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Requests/s al asistente por clínica",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (clinic_id) (rate(dentis_ia_request_seconds_count{application=\"dentis\", clinic_id=~\"$clinic_id\"}[5m]))",
        "legendFormat": "{{clinic_id}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Latencia P50 / P95 por clínica (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le, clinic_id) (rate(dentis_ia_request_seconds_bucket{application=\"dentis\", clinic_id=~\"$clinic_id\"}[5m])))",
          "legendFormat": "p50 {{clinic_id}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, clinic_id) (rate(dentis_ia_request_seconds_bucket{application=\"dentis\", clinic_id=~\"$clinic_id\"}[5m])))",
          "legendFormat": "p95 {{clinic_id}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Tokens/min — entrada vs salida",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(dentis_ia_tokens_total{application=\"dentis\", type=\"input\", clinic_id=~\"$clinic_id\"}[1m])) * 60",
          "legendFormat": "input tokens/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(dentis_ia_tokens_total{application=\"dentis\", type=\"output\", clinic_id=~\"$clinic_id\"}[1m])) * 60",
          "legendFormat": "output tokens/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Tokens por clínica (entrada + salida)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (clinic_id) (rate(dentis_ia_tokens_total{application=\"dentis\", clinic_id=~\"$clinic_id\"}[5m])) * 60",
        "legendFormat": "{{clinic_id}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Coste USD/min por clínica",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (clinic_id) (rate(dentis_ia_cost_usd_total{application=\"dentis\", clinic_id=~\"$clinic_id\"}[1m])) * 60",
        "legendFormat": "{{clinic_id}}"
      }],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 6, "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 10, "type": "bargauge", "title": "Coste acumulado por clínica (USD)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "sum by (clinic_id) (dentis_ia_cost_usd_total{application=\"dentis\", clinic_id=~\"$clinic_id\"})",
        "legendFormat": "{{clinic_id}}"
      }],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    }
  ]
}
