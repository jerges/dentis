# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dentis_db
DB_USER=dentis
DB_PASSWORD=dentis

# Docker Compose
COMPOSE_PROFILES=dev

# JWT (min 256 bits for HS256)
JWT_SECRET=dentis-jwt-secret-key-minimum-256-bits-long-for-hs256
JWT_EXPIRATION_MS=86400000

# Email (MailHog for development)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
